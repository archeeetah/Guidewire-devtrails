# ==============================================================================
# SHRAMSHIELD PRODUCTION ENVIRONMENT VARIABLES (AWS/DOCKER)
# ==============================================================================

# Backend API Configuration
# Replace with your actual AWS RDS connection string or use 'db:5432' for local Docker Compose
DATABASE_URL=postgresql://user:password@hostname:5432/dbname
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# AI & Third-Party APIs
GOOGLE_API_KEY=your_gemini_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Scanner Configuration
AUTO_SCAN_ENABLED=true
SCAN_INTERVAL_MINUTES=15

# Frontend Configuration (Server-side)
# Points to the backend URL for API proxy and server-side fetching
NEXT_PUBLIC_API_URL=http://backend:8000
# VERCEL_URL is also useful if deploying on Vercel concurrently
# NEXT_PUBLIC_VERCEL_URL=https://your-vercel-app.vercel.app

# Razorpay (Simulated)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAYX_ACCOUNT_NUMBER=2323230012345678
